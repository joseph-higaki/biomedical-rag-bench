@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rep: <http://www.openrdf.org/config/repository#> .
@prefix sr: <http://www.openrdf.org/config/repository/sail#> .
@prefix sail: <http://www.openrdf.org/config/sail#> .
@prefix graphdb: <http://www.ontotext.com/config/graphdb#> .

# GraphDB repository config for Project 1. Replaces the manual Workbench
# "Create repository" clicks in ingest/rdf/README.md so the repo is reproducible:
#   curl -X POST http://localhost:7200/rest/repositories \
#        -F "config=@ingest/rdf/graphdb-repo-config.ttl"
#
# ruleset = empty is a HARD CONSTRAINT for Project 1 (no reasoning; that is the
# variable Project 2 introduces). See .claude/CLAUDE.md. RDF-star needs no flag —
# GraphDB 10+ parses and stores quoted triples by default.

[] a rep:Repository ;
    rep:repositoryID "hetionet" ;
    rdfs:label "Hetionet (Project 1 baseline)" ;
    rep:repositoryImpl [
        rep:repositoryType "graphdb:SailRepository" ;
        sr:sailImpl [
            sail:sailType "graphdb:Sail" ;
            graphdb:ruleset "empty" ;
            graphdb:base-URL "https://het.io/" ;
            graphdb:enable-context-index "false" ;
            graphdb:enablePredicateList "true" ;
            graphdb:check-for-inconsistencies "false" ;
        ]
    ] .
