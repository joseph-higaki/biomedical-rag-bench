# Template for secrets/.env — copy to secrets/.env and fill in. The real file is
# gitignored; this .example is committed so a fresh clone shows what's needed.
#
# Loaded explicitly (find_dotenv does NOT look in subdirectories):
#   load_dotenv(Path(__file__).resolve().parents[N] / "secrets" / ".env")

# --- Generation LLM ---------------------------------------------------------
# Fixed within an eval run; logged with every result (see .claude/CLAUDE.md).
GENERATOR_MODEL=claude-opus-4-7

# Generator provider key. Required when GENERATOR_MODEL is a hosted Anthropic
# model. Leave unset for a local model (e.g. Llama via Ollama).
ANTHROPIC_API_KEY=

# Optional: only if a run uses an OpenAI generator, or the RAGAS eval uses an
# OpenAI judge model. Embeddings are local (all-MiniLM-L6-v2) and need no key.
OPENAI_API_KEY=

# --- PubMed fetch -----------------------------------------------------------
# Optional. Without it: 3 req/s. With it: 10 req/s. Get one at
# https://www.ncbi.nlm.nih.gov/account/ . See ingest/README.md.
NCBI_API_KEY=
