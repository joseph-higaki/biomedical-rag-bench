# Authoritative ground-truth record for this template. The registry generator
# (build_registry.py) copies the block below verbatim into eval/templates/README.md;
# --verify re-runs the query against GraphDB and asserts the live answer still
# equals the `answer` set. Keep it in sync with the query (or let --verify catch you).
#
# --- registry ---
# seed: Metformin
# seed_uri: db:DB00331
# chain: reference-entity label lookup (fuzzy/semantic — no traversal derives this answer)
# answer:
#   - Metformin
# --- end registry ---
#
# Type 10_fuzzy_semantic. Label lookup pinning the reference entity (Metformin), NOT an
# answer-deriving traversal — no edge encodes "first-line type 2 diabetes drug" (H4).
# The system answers the natural-language question; an LLM judge scores semantic
# equivalence to Metformin (accepting dimethylbiguanide / Glucophage).

PREFIX db: <https://identifiers.org/drugbank/>
PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?compound ?compoundLabel WHERE {
  VALUES ?compound { db:DB00331 }     # Metformin — reference entity, hand-chosen
  ?compound a hetio:Compound ;
            rdfs:label ?compoundLabel .
}
