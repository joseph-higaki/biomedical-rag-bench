# Ground-truth query for template: genes_expressed_in_anatomy (type 02_1hop_factoid)
# Returns the set of genes expressed in a given anatomy: Anatomy --expresses--> Gene.
#
# The VALUES block is the single substitution point. The eval producer (build step 3)
# rewrites the URI inside it with each sampled anatomy; everything else is fixed.
# Committed with a real full-graph URI (nasal cavity), chosen for a bounded
# expressed-gene fan so the ground-truth answer is small and enumerable. Run
# against the full Hetionet graph in GraphDB it should return exactly 4 genes:
#   CD79A, DCXR, OMP, RHNO1

PREFIX hetio: <https://het.io/schema/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX uberon: <http://purl.obolibrary.org/obo/UBERON_>

SELECT ?gene ?geneLabel WHERE {
  VALUES ?anatomy { uberon:0001707 }      # nasal cavity — producer rewrites this line
  ?anatomy hetio:expresses ?gene .
  ?gene rdfs:label ?geneLabel .
}
ORDER BY ?geneLabel
